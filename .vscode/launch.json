{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug FastAPI Backend",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "api:app",
                "--reload",
                "--port",
                "8000"
            ],
            "cwd": "${workspaceFolder}",
            "justMyCode": true
        },
        {
            "name": "Debug React Frontend (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/frontend",
            "preLaunchTask": "Start Vite Dev Server"
        }
    ],
    "compounds": [
        {
            "name": "Start Full Stack Debugging",
            "configurations": [
                "Debug FastAPI Backend",
                "Debug React Frontend (Chrome)"
            ]
        }
    ]
}
